# ── 서버 ──────────────────────────────────────────────
PORT=3000
# 관리자용 토큰: 수동 새로고침·관리 엔드포인트 보호. 반드시 임의의 긴 문자열로 교체.
ADMIN_TOKEN=change-me-to-a-long-random-string
# cron 엔드포인트(/api/cron/*) 보호용 Bearer 시크릿. 외부 스케줄러가 Authorization 헤더로 전달.
CRON_SECRET=change-me-to-a-long-random-string

# ── 데이터베이스 (Neon Postgres) ─────────────────────
# Neon 프로젝트의 연결 문자열(pooled 권장). 없으면 로컬 개발은 자동으로 PGlite 파일 사용.
# 예: postgresql://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=
# 강제 드라이버 선택(선택): pglite | memory | neon. 기본은 DATABASE_URL 유무로 자동 판단.
# DB_DRIVER=

# ── 스크래핑 ──────────────────────────────────────────
# 서버리스에서는 외부 스케줄러가 시각을 결정하므로 아래 cron 식은 참고용/로컬용.
SCRAPE_CRON=0 7 * * *
# 요청 간 딜레이(ms). 서버리스 300초 제한 대응으로 기본 800.
SCRAPE_DELAY_MS=800
# 1회 호출당 상세+LLM 처리 최대 건수(나머지는 다음 호출에서 이어서).
SCRAPE_DETAIL_BATCH=80

# ── OpenRouter (유통가능물량 추출용 LLM) ─────────────
# 실제 키는 .env 에만 저장하고 절대 커밋하지 않는다.
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=deepseek/deepseek-chat

# ── 웹푸시 (VAPID) ───────────────────────────────────
# `npm run gen:vapid` 로 생성해 아래에 채운다.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── 알림 정책 ────────────────────────────────────────
# 알림 발송 시각 (HH:MM, Asia/Seoul) — 외부 스케줄러 등록 시각과 맞춘다.
NOTIFY_HOUR=8
NOTIFY_MINUTE=30
# 마감 임박 알림 시각
NOTIFY_DEADLINE_HOUR=15
NOTIFY_DEADLINE_MINUTE=0
# true 이면 전체 종목 알림, false 이면 퍼펙트/청약 고려 종목만 알림
NOTIFY_ALL=false
