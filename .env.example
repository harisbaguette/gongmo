# ── 서버 ──────────────────────────────────────────────
PORT=3000
# 관리자용 토큰: 수동 새로고침·관리 엔드포인트 보호. 반드시 임의의 긴 문자열로 교체.
ADMIN_TOKEN=change-me-to-a-long-random-string

# ── 스크래핑 스케줄 ──────────────────────────────────
# node-cron 표현식 (Asia/Seoul 고정). 기본: 매일 07:00
SCRAPE_CRON=0 7 * * *
# 요청 간 딜레이(ms). 사이트 예의상 1000~2000 권장
SCRAPE_DELAY_MS=1500

# ── OpenRouter (유통가능물량 추출용 LLM) ─────────────
# 실제 키는 .env 에만 저장하고 절대 커밋하지 않는다.
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=deepseek/deepseek-chat

# ── 웹푸시 (VAPID) ───────────────────────────────────
# `npm run gen:vapid` 로 생성해 아래에 채운다.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── 알림 정책 ────────────────────────────────────────
# 알림 발송 시각 (HH:MM, Asia/Seoul)
NOTIFY_HOUR=8
NOTIFY_MINUTE=30
# 마감 임박 알림 시각
NOTIFY_DEADLINE_HOUR=15
NOTIFY_DEADLINE_MINUTE=0
# true 이면 전체 종목 알림, false 이면 퍼펙트/청약 고려 종목만 알림
NOTIFY_ALL=false
